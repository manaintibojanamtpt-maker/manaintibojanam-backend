# =============================================================================
# BhojanOS — Dev / Prod architecture (free-tier Spark safe)
# =============================================================================
#
# PRODUCTION (live customers)
#   Frontend : Vercel  → bhojanos.com
#   Backend  : Render  → manaintibojanam-backend.onrender.com
#   Firebase : bhojanos-prod (Firestore + Auth + Storage) — live customers
#   Pinger   : UptimeRobot/cron-job.org → GET /api/health every 10–14 min
#
# DEVELOPMENT (local + Vercel preview)
#   Frontend : localhost:8080 or Vercel Preview URL
#   Backend  : localhost:5000 (npm run dev) — do NOT point dev at prod Firestore for load tests
#   Firebase : create separate Spark project e.g. bhojanos-dev (own free quota)
#
# RETIRE: manaintibojanam Firebase for live traffic (legacy name only on Render URL)
# DO NOT: deploy same SPA to Vercel + Firebase Hosting (doubles Firestore reads)
#
# =============================================================================

# --- Platform tier ---
# free     = Spark-safe defaults (prod default on Render)
# standard = full AutoPilot crons + client telemetry (when on Blaze/paid)
PLATFORM_TIER=free
VITE_PLATFORM_TIER=free

# =============================================================================
# PRODUCTION — Render (manaintibojanam-backend)
# =============================================================================
NODE_ENV=production
PLATFORM_TIER=free
FIREBASE_PROJECT_ID=bhojanos-prod
FIREBASE_STORAGE_BUCKET=bhojanos-prod.firebasestorage.app
GOOGLE_CLOUD_PROJECT=bhojanos-prod
# Web SDK (also exposed via GET /api/client-config when Vercel env missing)
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_AUTH_DOMAIN=bhojanos-prod.firebaseapp.com
# Paste full JSON from Firebase → Project settings → Service accounts
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

EMAIL_USER=bhojanos26@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=BhojanOS <bhojanos26@gmail.com>
FOUNDER_EMAIL=bhojanos26@gmail.com
FOUNDER_NAME=The BhojanOS Team

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CRON_SECRET=long_random_secret

WORKER_INTERVAL_MS=600000
SETTINGS_CACHE_MS=600000
TENANT_CACHE_MS=600000
FIRESTORE_QUOTA_BACKOFF_MS=900000
CRON_STARTUP_DELAY_MS=120000
STOREFRONT_BASE_URL=https://bhojanos.com

# =============================================================================
# PRODUCTION — Vercel (Environment: Production)
# =============================================================================
VITE_APP_ENV=production
VITE_PLATFORM_TIER=free
VITE_API_URL=https://manaintibojanam-backend.onrender.com
VITE_FIREBASE_PROJECT_ID=bhojanos-prod
VITE_FIREBASE_AUTH_DOMAIN=bhojanos-prod.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=bhojanos-prod.firebasestorage.app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_RAZORPAY_KEY_ID=

# =============================================================================
# DEVELOPMENT — local .env (copy to .env.local)
# =============================================================================
# VITE_APP_ENV=development
# VITE_PLATFORM_TIER=standard
# VITE_API_URL=http://localhost:5000
# VITE_FIREBASE_PROJECT_ID=bhojanos-dev
# VITE_FIREBASE_AUTH_DOMAIN=bhojanos-dev.firebaseapp.com
# VITE_FIREBASE_STORAGE_BUCKET=bhojanos-dev.firebasestorage.app
# GOOGLE_CLOUD_PROJECT=bhojanos-dev
# FIREBASE_PROJECT_ID=bhojanos-dev

# =============================================================================
# DEVELOPMENT — Vercel (Environment: Preview only)
# =============================================================================
# Same as local dev — use bhojanos-dev so preview branches never burn prod quota

VITE_GOOGLE_MAPS_API_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
BIOMETRIC_SALT=
JWT_SECRET=
