rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
      );
    }
    function isWithinCancellationWindow(resource) {
      return request.time < resource.data.createdAt + duration.value(60, 's');
    }
    function isTenantOwner(tenantId) {
      return isAuthenticated() && (
        tenantId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownedTenantIds
      );
    }
    
    function isUnmodified(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }
    
    function allowsClientPaymentStatusChange() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['paymentStatus'])
        || request.resource.data.paymentStatus in ['pending', 'pending_verification', 'failed', 'expired', 'unpaid'];
    }

    function protectsServerPaymentFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'paymentVerifiedAt',
        'paymentVerifiedBy',
        'razorpayPaymentId',
        'paymentRail',
        'reconciliationSource',
        'reconciliationEventId'
      ]);
    }

    function isValidOrderStatusTransition(oldStatus, newStatus) {
      return 
        (oldStatus in ['CREATED', 'PLACED', 'PENDING'] && newStatus == 'ACCEPTED') ||
        (oldStatus == 'ACCEPTED' && newStatus == 'PREPARING') ||
        (oldStatus == 'PREPARING' && newStatus in ['READY', 'OUT_FOR_DELIVERY']) ||
        (oldStatus == 'READY' && newStatus == 'OUT_FOR_DELIVERY') ||
        (oldStatus == 'OUT_FOR_DELIVERY' && newStatus == 'DELIVERED') ||
        (newStatus == 'CANCELLED') ||
        (newStatus == 'REJECTED');
    }

    function isReservedSlug(slug) {
      return slug.matches('^dominos.*') ||
             slug.matches('^swiggy.*') ||
             slug.matches('^zomato.*') ||
             slug.matches('^kfc.*') ||
             slug.matches('^mcdonalds.*') ||
             slug.matches('^burgerking.*') ||
             slug.matches('^subway.*') ||
             slug.matches('^admin.*') ||
             slug.matches('^support.*') ||
             slug.matches('^api.*') ||
             slug.matches('^system.*') ||
             slug.matches('^bhojanos.*');
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /_connection_test_/{docId} {
      allow read, write: if true;
    }
    match /_admin_test_/{docId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && (
        isAdmin() || 
        (isOwner(userId) && 
         !request.resource.data.keys().hasAny(['permissions', 'isAdmin']) &&
         (!('role' in request.resource.data) || request.resource.data.role == 'owner' || request.resource.data.role == 'user')
        )
      );
      allow update: if isAuthenticated() && (
        isAdmin() || 
        request.auth.token.email == 'bhojanos26@gmail.com' ||
        request.auth.token.email == 'manaintibojanamtpt@gmail.com' ||
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'ownedTenantIds', 'permissions', 'isAdmin']))
      );
    }

    match /menu/{itemId} {
      allow read: if true;
      allow create: if isAdmin() || isTenantOwner(request.resource.data.tenantId);
      allow update: if isAdmin() || (isTenantOwner(resource.data.tenantId) && isTenantOwner(request.resource.data.tenantId));
      allow delete: if isAdmin() || isTenantOwner(resource.data.tenantId);
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        isTenantOwner(resource.data.tenantId)
      );
      allow create: if (isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid)) || (!isAuthenticated() && request.resource.data.userId == null);
      allow update: if isAuthenticated() && isUnmodified(['tenantId', 'userId', 'id', 'createdAt']) && allowsClientPaymentStatusChange() && protectsServerPaymentFields() && (
        (isAdmin() && isValidOrderStatusTransition(resource.data.status, request.resource.data.status)) ||
        (isTenantOwner(resource.data.tenantId) && isValidOrderStatusTransition(resource.data.status, request.resource.data.status)) ||
        (
          resource.data.userId == request.auth.uid &&
          (
            (
              request.resource.data.status == 'CANCELLED' &&
              resource.data.status in ['PLACED', 'PENDING'] &&
              isWithinCancellationWindow(resource) &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'timeline'])
            )
            ||
            (
              request.resource.data.status == resource.data.status &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'rating',
                'feedback',
                'reviewed',
                'feedbackStatus',
                'feedbackSubmittedAt',
                'updatedAt',
                'timeline'
              ])
            )
            ||
            (
              request.resource.data.status == resource.data.status &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'paymentSubmittedAt',
                'paymentProofType',
                'paymentProofValue',
                'paymentReferenceNumber',
                'updatedAt',
                'timeline'
              ])
            )
          )
        )
      );
    }

    match /payment_verifications/{verificationId} {
      allow read: if isAdmin() || isTenantOwner(resource.data.tenantId);
      allow write: if false;
    }

    match /order_drafts/{draftId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid) || 
        isTenantOwner(resource.data.tenantId)
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid) || 
        isTenantOwner(resource.data.tenantId)
      );
    }

    match /adminSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /userPreferences/{userId} {
      allow read, write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /supportTickets/{ticketId} {
      // Customers can create tickets for support
      allow create: if isAuthenticated();
      // Admin-only visibility and moderation
      allow read, update, delete: if isAdmin();
    }

    match /paymentProofs/{proofId} {
      allow create: if isAuthenticated() && request.resource.data.submittedBy == request.auth.uid &&
                    request.resource.data.orderId is string &&
                    request.resource.data.proofType in ['upi_screenshot', 'bank_transfer', 'card_transaction'] &&
                    request.resource.data.proofValue is string &&
                    request.resource.data.status == 'pending_review';
      allow read: if isAuthenticated() &&
                  (resource.data.submittedBy == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    match /razorpayWebhooks/{webhookId} {
      allow read, write: if isAdmin();
    }

    match /subscriptions/{subId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /referrals/{refId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /aiAnalytics/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /tenants/{tenantId} {
      allow read: if true;
      allow create: if isAuthenticated() && !isReservedSlug(tenantId) && (!('slug' in request.resource.data) || !isReservedSlug(request.resource.data.slug));
      allow update: if isAuthenticated() && (!('slug' in request.resource.data) || !isReservedSlug(request.resource.data.slug)) && (isAdmin() || request.auth.token.email == 'bhojanos26@gmail.com' || request.auth.token.email == 'manaintibojanamtpt@gmail.com' || isUnmodified(['createdAt', 'ownerId']));
      
      match /analytics/{docId} {
        allow read: if isAdmin() || isTenantOwner(tenantId);
        // Allowing create/update for the frontend AnalyticsService for now.
        // In a strict environment, this should only be writeable by Cloud Functions.
        allow write: if isAdmin() || isTenantOwner(tenantId) || isAuthenticated();
      }

      match /kycPrivate/{slot} {
        allow read: if isAdmin() || isTenantOwner(tenantId);
        allow write: if isAdmin() || isTenantOwner(tenantId);
      }
    }

    match /salesPipeline/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /campaigns/{docId} {
      allow read: if isAdmin() || isTenantOwner(resource.data.tenantId);
      allow create: if isAdmin() || isTenantOwner(request.resource.data.tenantId);
      allow update, delete: if isAdmin() || (isTenantOwner(resource.data.tenantId) && isTenantOwner(request.resource.data.tenantId));
    }

    match /audit_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Immutable
    }

    match /customers/{docId} {
      allow read: if isAdmin() || isTenantOwner(resource.data.tenantId);
      allow create: if isAdmin() || isTenantOwner(request.resource.data.tenantId);
      allow update: if isAdmin() || (isTenantOwner(resource.data.tenantId) && isTenantOwner(request.resource.data.tenantId));
      allow delete: if isAdmin() || isTenantOwner(resource.data.tenantId);
    }

    match /release_notes/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /release_views/{docId} {
      allow read: if isAuthenticated() && (isAdmin() || isTenantOwner(resource.data.tenantId));
      allow create: if isAuthenticated() && isTenantOwner(request.resource.data.tenantId);
      allow update, delete: if isAdmin();
    }
  }
}
