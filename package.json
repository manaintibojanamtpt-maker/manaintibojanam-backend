{
  "name": "react-example",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "seed": "tsx seed.ts",
    "audit:prod:read": "node read_prod_audit.mjs",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --target=node20 --outfile=dist/server.cjs --format=cjs --external:express --external:cors --external:body-parser --external:firebase-admin --external:vite --external:node-cron",
    "build:web": "node scripts/verify-vercel-firebase-env.mjs && node scripts/write-version-json.mjs && vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node20 --outfile=dist/server.cjs --format=cjs --external:express --external:cors --external:body-parser --external:firebase-admin --external:vite --external:node-cron",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy --only hosting",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:smoke": "tsx scripts/preprod-smoke-test.ts",
    "test:preprod": "npm run lint && npm run build && npm run test:smoke",
    "docs:owner-guide": "node scripts/generate-owner-guide-pdf.mjs",
    "docs:owner-guide-full": "node scripts/generate-owner-guide-full.mjs",
    "docs:owner-guide-capture": "node scripts/capture-guide-screenshots.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/preferences": "^8.0.1",
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.14.0",
    "base64url": "^3.0.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "capacitor-native-biometric": "^4.2.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.5.0",
    "nodemailer": "^8.0.4",
    "qrcode.react": "^4.2.0",
    "razorpay": "^2.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-google-recaptcha": "^3.1.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "source-map": "^0.8.0-beta.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "winston": "^3.19.0",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-window": "^7.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-google-recaptcha": "^2.1.9",
    "autoprefixer": "^10.4.21",
    "puppeteer": "^25.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
